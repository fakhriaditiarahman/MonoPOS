# Supabase Configuration
# Override these with --dart-define at build time:
# flutter run --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...
#
# S3 Storage Configuration (for Supabase Storage S3-compatible API):
# flutter run --dart-define=S3_ACCESS_KEY=... --dart-define=S3_SECRET_KEY=...
#   --dart-define=S3_ENDPOINT=... --dart-define=S3_REGION=...
#
# Default development values are in lib/core/services/supabase/supabase_config.dart
